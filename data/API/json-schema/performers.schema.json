{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "performers.schema.json",
  "type": "object",
  "required": [
    "items",
    "count",
    "page",
    "pageSize"
  ],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "genre",
          "country",
          "bio"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^p[0-9]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "genre": {
            "type": "string",
            "enum": [
              "Electronic",
              "Indie",
              "Alternative",
              "Hip-Hop",
              "Experimental",
              "Ambient",
              "Synth-pop",
              "World Fusion"
            ]
          },
          "country": {
            "type": "string",
            "minLength": 1
          },
          "bio": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1
    },
    "totalPages": {
      "type": "integer",
      "minimum": 1
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "genre": {
          "type": "string",
          "enum": [
            "Electronic",
            "Indie",
            "Alternative",
            "Hip-Hop",
            "Experimental",
            "Ambient",
            "Synth-pop",
            "World Fusion"
          ]
        }
      }
    }
  }
}