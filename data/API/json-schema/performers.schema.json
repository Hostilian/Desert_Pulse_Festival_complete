{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "items",
    "count"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "genre",
          "country",
          "bio"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "genre": {
            "type": "string"
          },
          "country": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          }
        }
      }
    },
    "count": {
      "type": "integer"
    },
    "page": {
      "type": "integer"
    },
    "pageSize": {
      "type": "integer"
    },
    "totalPages": {
      "type": "integer"
    },
    "filters": {
      "type": "object"
    }
  }
}