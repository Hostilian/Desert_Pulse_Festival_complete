{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "events.schema.json",
  "type": "object",
  "required": [
    "items",
    "count",
    "page",
    "pageSize"
  ],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "title",
          "performerId",
          "venueId",
          "start",
          "end",
          "description"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^e[0-9]+$"
          },
          "type": {
            "type": "string",
            "enum": ["concert", "workshop", "talk", "dj-set"]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "performerId": {
            "type": "string",
            "pattern": "^p[0-9]+$"
          },
          "venueId": {
            "type": "string",
            "pattern": "^v[0-9]+$"
          },
          "start": {
            "type": "string",
            "format": "date-time"
          },
          "end": {
            "type": "string",
            "format": "date-time"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1
    },
    "totalPages": {
      "type": "integer",
      "minimum": 1
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "day": {
          "type": "string",
          "format": "date"
        },
        "venueId": {
          "type": "string",
          "pattern": "^v[0-9]+$"
        },
        "performerId": {
          "type": "string",
          "pattern": "^p[0-9]+$"
        }
      }
    }
  }
}