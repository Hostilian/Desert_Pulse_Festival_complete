{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "items",
    "count"
  ],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "capacity",
          "description",
          "area",
          "geo"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "capacity": {
            "type": "integer"
          },
          "description": {
            "type": "string"
          },
          "area": {
            "type": "string"
          },
          "geo": {
            "type": "string"
          }
        }
      }
    },
    "count": {
      "type": "integer"
    },
    "page": {
      "type": "integer"
    },
    "pageSize": {
      "type": "integer"
    },
    "totalPages": {
      "type": "integer"
    },
    "filters": {
      "type": "object"
    }
  }
}