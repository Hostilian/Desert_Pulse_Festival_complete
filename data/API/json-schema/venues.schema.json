{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "venues.schema.json",
  "type": "object",
  "required": [
    "items",
    "count"
  ],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "capacity",
          "description",
          "area",
          "geo"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^v[0-9]+$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "capacity": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "area": {
            "type": "string",
            "minLength": 1
          },
          "geo": {
            "type": "string",
            "pattern": "^-?[0-9]+\\.[0-9]+,-?[0-9]+\\.[0-9]+$"
          }
        }
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "page": {
      "type": "integer",
      "minimum": 1
    },
    "pageSize": {
      "type": "integer",
      "minimum": 1
    },
    "totalPages": {
      "type": "integer",
      "minimum": 1
    },
    "filters": {
      "type": "object",
      "additionalProperties": false
    }
  }
}