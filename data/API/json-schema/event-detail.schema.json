{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event-detail.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "performerId",
    "venueId",
    "start",
    "end",
    "description"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^e[0-9]+$"
    },
    "type": {
      "type": "string",
      "enum": ["concert", "workshop", "talk", "dj-set"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "performerId": {
      "type": "string",
      "pattern": "^p[0-9]+$"
    },
    "venueId": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "start": {
      "type": "string",
      "format": "date-time"
    },
    "end": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string",
      "minLength": 1
    }
  }
}