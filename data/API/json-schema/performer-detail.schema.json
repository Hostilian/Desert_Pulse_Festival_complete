{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "performer-detail.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "genre",
    "country",
    "bio"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^p[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "genre": {
      "type": "string",
      "enum": [
        "Electronic",
        "Indie",
        "Alternative",
        "Hip-Hop",
        "Experimental",
        "Ambient",
        "Synth-pop",
        "World Fusion"
      ]
    },
    "country": {
      "type": "string",
      "minLength": 1
    },
    "bio": {
      "type": "string",
      "minLength": 1
    }
  }
}