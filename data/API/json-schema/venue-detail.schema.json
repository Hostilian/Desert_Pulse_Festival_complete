{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "venue-detail.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "capacity",
    "description",
    "area",
    "geo"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "capacity": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "area": {
      "type": "string",
      "minLength": 1
    },
    "geo": {
      "type": "string",
      "pattern": "^-?[0-9]+\\.[0-9]+,-?[0-9]+\\.[0-9]+$"
    }
  }
}