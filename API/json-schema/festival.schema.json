{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "festival.schema.json",
  "type": "object",
  "required": [
    "id",
    "name",
    "year",
    "edition",
    "location",
    "startDate",
    "endDate",
    "description",
    "tickets",
    "links"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "edition": {
      "type": "integer"
    },
    "location": {
      "type": "string"
    },
    "startDate": {
      "type": "string",
      "format": "date"
    },
    "endDate": {
      "type": "string",
      "format": "date"
    },
    "description": {
      "type": "string"
    },
    "tickets": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "links": {
      "type": "object",
      "properties": {
        "website": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}