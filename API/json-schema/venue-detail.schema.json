{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "name",
    "capacity",
    "description",
    "area",
    "geo"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "capacity": {
      "type": "integer"
    },
    "description": {
      "type": "string"
    },
    "area": {
      "type": "string"
    },
    "geo": {
      "type": "string"
    }
  }
}